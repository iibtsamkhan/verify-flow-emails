# Database (Recommended: Neon PostgreSQL)
DATABASE_URL="postgresql://<user>:<password>@<host>/<db>?sslmode=require"

# Verify engine service
VERIFYFLOW_ENGINE_URL="http://localhost:8080"
VERIFYFLOW_TIMEOUT_BUCKETS_MS="5000,9000,14000"
VERIFYFLOW_RETRY_BACKOFF_MS="250"
VERIFYFLOW_EMAIL_CONCURRENCY="8"
VERIFYFLOW_MAX_PARALLEL_JOBS="2"
VERIFYFLOW_DOMAIN_MIN_INTERVAL_MS="35"
VERIFYFLOW_USER_JOBS_PER_MINUTE="12"
VERIFYFLOW_IP_JOBS_PER_MINUTE="30"

# Clerk auth (user dashboard)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Optional Clerk route behavior
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Credit system
DEFAULT_TRIAL_CREDITS="100"

# Paddle checkout links
NEXT_PUBLIC_PADDLE_CHECKOUT_STARTER_URL="https://pay.paddle.com/checkout/<starter_price_or_link>"
NEXT_PUBLIC_PADDLE_CHECKOUT_GROWTH_URL="https://pay.paddle.com/checkout/<growth_price_or_link>"
NEXT_PUBLIC_PADDLE_CHECKOUT_SCALE_URL="https://pay.paddle.com/checkout/<scale_price_or_link>"
NEXT_PUBLIC_PADDLE_CUSTOMER_PORTAL_URL="https://customer-portal.paddle.com/<portal_link>"

# Admin bootstrap + session security
ADMIN_DEFAULT_EMAIL="admin@verifyflow.com"
ADMIN_DEFAULT_PASSWORD="change-this-super-admin-password"
ADMIN_SESSION_SECRET="replace-with-very-long-random-string-at-least-32-chars"
ADMIN_SESSION_DAYS="7"
